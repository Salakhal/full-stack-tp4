<%- include('../../partials/header') %>

<div class="page-header">
    <div>
        <h1>✍️ Nos Auteurs</h1>
        <p class="subtitle">Découvrez la richesse de notre communauté littéraire</p>
    </div>
    <a href="/auteurs/ajouter" class="btn btn-primary">
        <i class="fas fa-plus"></i> Ajouter un auteur
    </a>
</div>

<div class="authors-stats">
    <div class="stat-card">
        <span class="stat-number"><%= auteurs.length %></span>
        <span class="stat-label">Auteurs</span>
    </div>
    <div class="stat-card">
        <span class="stat-number"><%= auteurs.filter(a => a.nationalite === 'Française').length %></span>
        <span class="stat-label">Français</span>
    </div>
    <div class="stat-card">
        <span class="stat-number"><%= auteurs.reduce((sum, a) => sum + (a.nb_livres || 0), 0) %></span>
        <span class="stat-label">Livres</span>
    </div>
</div>

<div class="authors-container">
    <% if(auteurs.length === 0) { %>
        <div class="empty-state">
            <i class="fas fa-user-friends"></i>
            <h3>Aucun auteur</h3>
            <p>Commencez par ajouter votre premier auteur</p>
            <a href="/auteurs/ajouter" class="btn btn-primary">Ajouter un auteur</a>
        </div>
    <% } else { %>
        <div class="authors-grid">
            <% auteurs.forEach(auteur => { 
                const dateNaissance = auteur.date_naissance ? new Date(auteur.date_naissance).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }) : 'Date inconnue';
            %>
                <div class="author-card">
                    <div class="author-card-header">
                        <div class="author-avatar">
                            <i class="fas fa-user-circle"></i>
                        </div>
                        <div class="author-badge">
                            <i class="fas fa-book-open"></i> <%= auteur.nb_livres || 0 %> livre(s)
                        </div>
                    </div>
                    
                    <div class="author-card-body">
                        <h3><%= auteur.prenom %> <%= auteur.nom %></h3>
                        
                        <div class="author-info">
                            <div class="info-row">
                                <i class="fas fa-flag"></i>
                                <span><%= auteur.nationalite || 'Nationalité non spécifiée' %></span>
                            </div>
                            <div class="info-row">
                                <i class="fas fa-calendar-alt"></i>
                                <span class="format-date"><%= dateNaissance %></span>
                            </div>
                        </div>
                        
                        <% if(auteur.biographie) { %>
                            <p class="author-bio"><%= auteur.biographie.substring(0, 100) %><%= auteur.biographie.length > 100 ? '...' : '' %></p>
                        <% } %>
                    </div>
                    
                    <div class="author-card-footer">
                        <a href="/auteurs/<%= auteur.id %>" class="btn-action btn-view" title="Voir les détails">
                            <i class="fas fa-eye"></i> Détails
                        </a>
                        <a href="/auteurs/<%= auteur.id %>/modifier" class="btn-action btn-edit" title="Modifier">
                            <i class="fas fa-edit"></i> Modifier
                        </a>
                        <form action="/auteurs/<%= auteur.id %>/supprimer" method="POST" class="inline-form">
                            <button type="submit" class="btn-action btn-delete" title="Supprimer" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cet auteur ?')">
                                <i class="fas fa-trash-alt"></i> Supprimer
                            </button>
                        </form>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<%- include('../../partials/footer') %>