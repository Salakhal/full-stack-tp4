<%- include('../../partials/header') %>

<div class="form-container">
    <h1><i class="fas fa-book"></i> Ajouter un livre</h1>
    
    <form action="/livres/ajouter" method="POST" class="form">
        <!-- Titre -->
        <div class="form-group">
            <label for="titre">
                <i class="fas fa-heading"></i> Titre *
            </label>
            <input type="text" id="titre" name="titre" required 
                   class="form-control" placeholder="Ex: Les Misérables">
        </div>

        <!-- Auteur (UN SEUL) -->
        <div class="form-group">
            <label for="auteur_id">
                <i class="fas fa-user"></i> Auteur *
            </label>
            <select id="auteur_id" name="auteur_id" required class="form-control">
                <option value="">-- Sélectionnez un auteur --</option>
                <% auteurs.forEach(auteur => { %>
                    <option value="<%= auteur.id %>">
                        <%= auteur.prenom %> <%= auteur.nom %>
                    </option>
                <% }) %>
            </select>
            <small class="form-hint">
                <i class="fas fa-info-circle"></i> 
                Vous ne trouvez pas l'auteur ? 
                <a href="/auteurs/ajouter">Ajoutez-le d'abord</a>
            </small>
        </div>

        <!-- Année et Genre (2 colonnes) -->
        <div class="form-row">
            <div class="form-group">
                <label for="annee_publication">
                    <i class="fas fa-calendar"></i> Année de publication
                </label>
                <input type="number" id="annee_publication" name="annee_publication" 
                       class="form-control" placeholder="Ex: 1862" min="1000" max="2026">
            </div>

            <div class="form-group">
                <label for="genre">
                    <i class="fas fa-tag"></i> Genre
                </label>
                <input type="text" id="genre" name="genre" 
                       class="form-control" placeholder="Ex: Roman, Fantasy, Policier...">
            </div>
        </div>

        <!-- ISBN -->
        <div class="form-group">
            <label for="isbn">
                <i class="fas fa-barcode"></i> ISBN
            </label>
            <input type="text" id="isbn" name="isbn" 
                   class="form-control" placeholder="Ex: 9782253096344">
        </div>

        <!-- Résumé -->
        <div class="form-group">
            <label for="resume">
                <i class="fas fa-align-left"></i> Résumé
            </label>
            <textarea id="resume" name="resume" rows="5" 
                      class="form-control" placeholder="Décrivez brièvement le livre..."></textarea>
        </div>

        <!-- Disponible (checkbox) -->
        <div class="form-group checkbox">
            <label>
                <input type="checkbox" name="disponible" checked>
                <i class="fas fa-check-circle"></i> Livre disponible
            </label>
        </div>

        <!-- Boutons d'action -->
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> Enregistrer
            </button>
            <a href="/livres" class="btn btn-secondary">
                <i class="fas fa-times"></i> Annuler
            </a>
        </div>
    </form>
</div>

<%- include('../../partials/footer') %>