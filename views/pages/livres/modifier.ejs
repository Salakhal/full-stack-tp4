<%- include('../../partials/header') %>

<div class="form-container">
    <h1><i class="fas fa-edit"></i> Modifier le livre</h1>
    
    <form action="/livres/<%= livre.id %>/modifier" method="POST" class="form">
        <!-- Titre -->
        <div class="form-group">
            <label for="titre">
                <i class="fas fa-heading"></i> Titre *
            </label>
            <input type="text" id="titre" name="titre" value="<%= livre.titre %>" 
                   required class="form-control">
        </div>

        <!-- Auteur (UN SEUL) -->
        <div class="form-group">
            <label for="auteur_id">
                <i class="fas fa-user"></i> Auteur *
            </label>
            <select id="auteur_id" name="auteur_id" required class="form-control">
                <option value="">-- Sélectionnez un auteur --</option>
                <% auteurs.forEach(auteur => { %>
                    <option value="<%= auteur.id %>" 
                            <%= livre.auteur_id == auteur.id ? 'selected' : '' %>>
                        <%= auteur.prenom %> <%= auteur.nom %>
                    </option>
                <% }) %>
            </select>
        </div>

        <!-- Année et Genre -->
        <div class="form-row">
            <div class="form-group">
                <label for="annee_publication">
                    <i class="fas fa-calendar"></i> Année de publication
                </label>
                <input type="number" id="annee_publication" name="annee_publication" 
                       value="<%= livre.annee_publication %>" class="form-control">
            </div>

            <div class="form-group">
                <label for="genre">
                    <i class="fas fa-tag"></i> Genre
                </label>
                <input type="text" id="genre" name="genre" 
                       value="<%= livre.genre %>" class="form-control">
            </div>
        </div>

        <!-- ISBN -->
        <div class="form-group">
            <label for="isbn">
                <i class="fas fa-barcode"></i> ISBN
            </label>
            <input type="text" id="isbn" name="isbn" 
                   value="<%= livre.isbn %>" class="form-control">
        </div>

        <!-- Résumé -->
        <div class="form-group">
            <label for="resume">
                <i class="fas fa-align-left"></i> Résumé
            </label>
            <textarea id="resume" name="resume" rows="5" 
                      class="form-control"><%= livre.resume %></textarea>
        </div>

        <!-- Disponible -->
        <div class="form-group checkbox">
            <label>
                <input type="checkbox" name="disponible" <%= livre.disponible ? 'checked' : '' %>>
                <i class="fas fa-check-circle"></i> Livre disponible
            </label>
        </div>

        <!-- Boutons -->
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> Mettre à jour
            </button>
            <a href="/livres/<%= livre.id %>" class="btn btn-secondary">
                <i class="fas fa-times"></i> Annuler
            </a>
        </div>
    </form>
</div>

<%- include('../../partials/footer') %>